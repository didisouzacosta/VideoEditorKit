    "Keeps important content inside the clearer viewing area for YouTube Shorts, away from top labels and lower playback overlays." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Hält wichtige Inhalte innerhalb des klareren Sichtbereichs von YouTube Shorts und fern von oberen Labels und unteren Wiedergabe-Overlays."
          }
        }, 
        "en" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Keeps important content inside the clearer viewing area for YouTube Shorts, away from top labels and lower playback overlays."
          }
        }, 
        "es" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Mantiene el contenido importante dentro del área de visualización más limpia de YouTube Shorts, lejos de las etiquetas superiores y las superposiciones inferiores de reproducción."
          }
        }, 
        "fr" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Garde le contenu important dans la zone de visualisation la plus claire de YouTube Shorts, à l'écart des libellés supérieurs et des superpositions de lecture inférieures."
          }
        }, 
        "ja" : {
          "stringUnit" : {
            "state" : "translated", 
