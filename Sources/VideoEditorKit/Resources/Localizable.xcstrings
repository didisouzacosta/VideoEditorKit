    "editor.crop.helper" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Wähle ein Preset. Original unterstützt auch Ziehen und Zoomen. Tippe doppelt oder nutze Zurücksetzen, um zum vollständigen Bild zurückzukehren."
          }
        }, 
        "en" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Choose a preset. Original also supports drag and pinch. Double tap or use reset to go back to full."
          }
        }, 
        "es" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Elige un preset. Original también admite arrastrar y pellizcar. Toca dos veces o usa restablecer para volver al encuadre completo."
          }
        }, 
        "fr" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Choisissez un preset. Original prend aussi en charge le glisser-déposer et le pincement. Touchez deux fois ou utilisez réinitialiser pour revenir au cadrage complet."
          }
        }, 
        "ja" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "プリセットを選択してください。オリジナルではドラッグとピンチにも対応しています。全体表示に戻るにはダブルタップするか、リセットを使ってください。"
          }
        }, 
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Escolha um preset. Original também permite arrastar e pinçar. Toque duas vezes ou use redefinir para voltar ao enquadramento completo."
          }
        }, 
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "选择一个预设。原始模式也支持拖动和捏合。双击或使用重置可返回完整画面。"
          }
        }
      }
    }, 
