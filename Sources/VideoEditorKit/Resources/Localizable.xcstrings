    "example.host-video-duration.detail.empty" : {
      "extractionState" : "stale", 
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Lass das Feld leer, wenn der Editor ohne Trimmbegrenzung bleiben soll. Beispiel: Gib 300 ein, um Trimmen und Export auf 5 Minuten zu begrenzen."
          }
        }, 
        "en" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Leave the field empty to keep the editor without a trim limit. Example: enter 300 to cap trim and export at 5 minutes."
          }
        }, 
        "es" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Deja el campo vacío para mantener el editor sin límite de recorte. Ejemplo: ingresa 300 para limitar el recorte y la exportación a 5 minutos."
          }
        }, 
        "fr" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Laissez le champ vide pour garder l’éditeur sans limite de découpe. Exemple : saisissez 300 pour limiter la découpe et l’export à 5 minutes."
          }
        }, 
        "ja" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "トリム制限なしでエディタを使う場合は、この欄を空のままにします。例: 300 と入力すると、トリムと書き出しを 5 分に制限できます。"
          }
        }, 
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Deixe o campo vazio para manter o editor sem limite de corte. Exemplo: digite 300 para limitar o corte e a exportação a 5 minutos."
          }
        }, 
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "将此字段留空即可让编辑器不设置裁剪时长限制。示例：输入 300，可将裁剪和导出限制为 5 分钟。"
          }
        }
      }
    }, 
    "example.host-video-duration.detail.maximum-format" : {
      "extractionState" : "stale", 
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Der Host begrenzt Trimmen und Export auf %lld Sekunden. Das ausgewählte Fenster kann weiterhin frei innerhalb des Quellvideos verschoben werden, seine Länge darf diesen Wert jedoch nicht überschreiten."
          }
        }, 
        "en" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "The host is limiting trim and export to %lld seconds. The user can still move the selected window anywhere in the source video, but the trim selection itself cannot exceed that duration."
          }
        }, 
        "es" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "El host está limitando el recorte y la exportación a %lld segundos. El usuario aún puede mover la ventana seleccionada a cualquier parte del video de origen, pero el recorte en sí no puede superar esa duración."
          }
        }, 
        "fr" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "L’hôte limite la découpe et l’export à %lld secondes. L’utilisateur peut toujours déplacer la fenêtre sélectionnée n’importe où dans la vidéo source, mais la sélection elle-même ne peut pas dépasser cette durée."
          }
        }, 
        "ja" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "ホストはトリミングと書き出しを %lld 秒に制限しています。ユーザーは選択範囲を元のビデオ内で自由に移動できますが、トリム範囲そのものはこの長さを超えられません。"
          }
        }, 
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "O host está limitando o corte e a exportação a %lld segundos. O usuário ainda pode mover a janela selecionada para qualquer ponto do vídeo de origem, mas a seleção em si não pode ultrapassar essa duração."
          }
        }, 
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "宿主当前将裁剪和导出限制为 %lld 秒。用户仍然可以在源视频中任意移动所选窗口，但裁剪选区本身不能超过这个时长。"
          }
        }
      }
    }, 
