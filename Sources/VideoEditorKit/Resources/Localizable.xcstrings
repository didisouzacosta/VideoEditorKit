    "Based on the current Instagram Reels and Stories safe-zone guidance. Keep key text, logos and CTAs away from the top 14%, bottom 35% and outer 6% on each side." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Basierend auf der aktuellen Safe-Zone-Empfehlung für Instagram Reels und Stories. Halte wichtige Texte, Logos und CTAs von den oberen 14%, unteren 35% und den äußeren 6% jeder Seite fern."
          }
        }, 
        "en" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Based on the current Instagram Reels and Stories safe-zone guidance. Keep key text, logos and CTAs away from the top 14%, bottom 35% and outer 6% on each side."
          }
        }, 
        "es" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Basado en la guía actual de zona segura para Reels y Stories de Instagram. Mantén textos clave, logotipos y CTAs lejos del 14% superior, 35% inferior y 6% exterior de cada lado."
          }
        }, 
        "fr" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Basé sur les consignes actuelles de zone sûre pour les Reels et Stories Instagram. Gardez les textes clés, logos et CTA à l'écart des 14% supérieurs, des 35% inférieurs et des 6% extérieurs de chaque côté."
          }
        }, 
        "ja" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Instagram Reels と Stories の現在のセーフゾーンガイドに基づいています。重要なテキスト、ロゴ、CTA は上部 14%、下部 35%、左右外側 6% から離して配置してください。"
          }
        }, 
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Baseado na orientação atual de área segura para Reels e Stories do Instagram. Mantenha textos importantes, logos e CTAs longe dos 14% superiores, 35% inferiores e 6% externos de cada lado."
          }
        }, 
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "基于当前 Instagram Reels 和 Stories 的安全区指引。请将关键文字、标志和 CTA 远离顶部 14%、底部 35% 以及两侧外缘各 6% 的区域。"
          }
        }
      }
    }, 
