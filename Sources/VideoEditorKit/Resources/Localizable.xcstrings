    "editor.platform.tiktok.explanation" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Hält wichtige Inhalte innerhalb des klareren Sichtbereichs von TikTok und fern von oberer UI, rechten Aktionen und unteren Untertiteln."
          }
        }, 
        "en" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Keeps important content inside TikTok's clearer viewing area, away from top chrome, right-side actions and lower captions."
          }
        }, 
        "es" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Mantiene el contenido importante dentro del área de visualización más limpia de TikTok, lejos de la barra superior, las acciones laterales derechas y los subtítulos inferiores."
          }
        }, 
        "fr" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Garde le contenu important dans la zone de visualisation la plus claire de TikTok, à l'écart de l'interface supérieure, des actions à droite et des sous-titres inférieurs."
          }
        }, 
        "ja" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "重要なコンテンツを、TikTok の上部 UI、右側のアクション、下部のキャプションから離れた、見やすい表示エリア内に保ちます。"
          }
        }, 
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "Mantém o conteúdo importante dentro da área mais limpa de visualização do TikTok, longe dos elementos superiores, das ações na lateral direita e das legendas inferiores."
          }
        }, 
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated", 
            "value" : "将重要内容保持在 TikTok 更清晰的观看区域内，避开顶部界面、右侧操作区和底部字幕区域。"
          }
        }
      }
    }, 
